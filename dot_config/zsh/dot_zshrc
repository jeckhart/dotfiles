# ~/.config/zsh/.zshrc — interactive shell config.
# Files live under $ZDOTDIR (set in ~/.zshenv to ~/.config/zsh).

# load custom executable functions
for function in $ZDOTDIR/functions/*; do
  source $function
done

# extra files in $ZDOTDIR/configs/pre , $ZDOTDIR/configs , and $ZDOTDIR/configs/post
# are loaded first, second, and third, respectively.
_load_settings() {
  # pre/ and post/ globs below use `~*.zwc` (exclude compiled files), which needs
  # EXTENDED_GLOB. configs/options.zsh also sets this, but that's a top-level config
  # loaded *after* the pre/ pass below — too late for it, so pre/ silently matched
  # nothing and every pre/ file (e.g. pre/brew.zsh) was skipped. Set it here so both
  # passes work regardless of load order.
  setopt extended_glob
  _dir="$1"
  if [ -d "$_dir" ]; then
    if [ -d "$_dir/pre" ]; then
      for config in "$_dir"/pre/**/*~*.zwc(N-.); do
        . $config
      done
    fi

    for config in "$_dir"/**/*(N-.); do
      case "$config" in
        "$_dir"/(pre|post)/*|*.zwc)
          :
          ;;
        *)
          . $config
          ;;
      esac
    done

    if [ -d "$_dir/post" ]; then
      for config in "$_dir"/post/**/*~*.zwc(N-.); do
        . $config
      done
    fi
  fi
}
_load_settings "$ZDOTDIR/configs"
