# Radicle node environment — sourced by the node supervisor (LaunchAgent wrapper on
# macOS, systemd EnvironmentFile on WSL2). Rendered by chezmoi from 1Password; the
# passphrase never lives in the repo. Strict KEY=value (no quotes): rad-bootstrap
# generates alphanumeric-only passphrases so no escaping is needed.
RAD_HOME={{ .chezmoi.homeDir }}/.radicle
RAD_PASSPHRASE={{ onepasswordRead (printf "op://%s/radicle-node-%s/passphrase" .opVault (.chezmoi.hostname | lower)) | trim }}
