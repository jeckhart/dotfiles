[init]
	defaultBranch = main
[alias]
	aa = add --all
	ap = add --patch
	ci = commit -v
	co = checkout
	pf = push --force-with-lease
	st = status
	branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes
[core]
	excludesfile = ~/.config/git/ignore
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	; Catppuccin Macchiato — defined in the included catppuccin.gitconfig below.
	; Self-contained (does not depend on `bat cache`).
	features = catppuccin-macchiato
[color]
	ui = auto
[push]
	default = simple
	autoSetupRemote = true
[fetch]
	prune = true
	pruneTags = true
[rebase]
	autosquash = true
	autoStash = true
	updateRefs = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = zebra
	algorithm = histogram
	colorMovedWS = allow-indentation-change
[rerere]
	enabled = true
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[column]
	ui = auto
[include]
	path = ~/.config/git/catppuccin.gitconfig
[include]
	path = ~/.config/git/config.local
