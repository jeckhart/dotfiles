{{ if eq .chezmoi.os "darwin" -}}
#!/bin/sh
# Enable Touch ID for sudo via /etc/pam.d/sudo_local (survives macOS updates),
# with pam_reattach so it also works inside tmux/screen sessions.
# Prompts for an admin password once on first run; re-runs if this script changes.
set -e

# On nix-darwin machines the work layer owns this file
# (security.pam.services.sudo_local.{touchIdAuth,reattach}) — leave it alone.
if [ -e /run/current-system/darwin-version ]; then
  exit 0
fi

reattach_mod="$(brew --prefix 2>/dev/null || true)/lib/pam/pam_reattach.so"

want="auth       sufficient     pam_tid.so"
if [ -f "$reattach_mod" ]; then
  want="auth       optional       $reattach_mod ignore_ssh
$want"
fi

if [ "$(cat /etc/pam.d/sudo_local 2>/dev/null)" = "$want" ]; then
  exit 0
fi

echo "Configuring Touch ID for sudo (/etc/pam.d/sudo_local) — admin password required:"
printf '%s\n' "$want" | sudo tee /etc/pam.d/sudo_local >/dev/null
{{ end -}}
