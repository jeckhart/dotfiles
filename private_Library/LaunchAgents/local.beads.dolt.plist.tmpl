<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>local.beads.dolt</string>
	<key>LimitLoadToSessionType</key>
	<array>
		<string>Aqua</string>
		<string>Background</string>
		<string>LoginWindow</string>
		<string>StandardIO</string>
		<string>System</string>
	</array>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>{{ .chezmoi.homeDir }}/.local/bin/beads-dolt-server.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/opt/homebrew/var/log/dolt.error.log</string>
	<key>StandardOutPath</key>
	<string>/opt/homebrew/var/log/dolt.log</string>
	<key>WorkingDirectory</key>
	<string>{{ .chezmoi.homeDir }}/.beads/shared-server/dolt</string>
</dict>
</plist>
